# General Server Configurations
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# Firebase Database
# Retrieve the Database URL from your Firebase console
FIREBASE_DATABASE_URL=https://abhi-services-email-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Authentication Service Account Options
# Path to your Firebase service account JSON key file (relative or absolute)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Alternatively, you can pass individual service account values directly (recommended for Render/production):
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyLine1\nYourPrivateKeyLine2...\n-----END PRIVATE KEY-----\n"
# Or pass the entire service account JSON contents stringified:
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'

# Redis Configuration (BullMQ & Cache backend)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_if_any

# Hostinger SMTP configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=abhishek@abhi.services
SMTP_PASS=asrvcs@123
SMTP_FROM_NAME="Abhi Services Outreach"

# JWT Secret Keys (For Team authentication and refresh tokens)
JWT_SECRET=abhi_services_secret_key
JWT_REFRESH_SECRET=abhi_services_refresh_key

# Webhook Authorization (Secure connection from n8n to backend)
# Set a secret token that n8n must pass in request headers (e.g. 'x-webhook-secret') or parameters
WEBHOOK_SECRET=abhi_services_webhook_secret_123

# Express Rate Limiting Settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Testing Mode (If true, BullMQ followups run in 15 seconds instead of 3, 7, 14 days)
TESTING_MODE=true
